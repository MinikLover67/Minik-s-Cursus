{
  "name": "cursus",
  "version": "1.0.0",
  "description": "AI-powered rich text editor for students and teachers",
  "main": "dist/main/index.js",
  "author": "Minik",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "esbuild electron/main/index.ts --outfile=dist/main/index.js --platform=node --format=esm --external:electron --external:node-llama-cpp --external:node:* --watch",
    "dev:renderer": "vite serve src --config vite.renderer.config.ts",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "esbuild electron/main/index.ts --bundle --outfile=dist/main/index.js --platform=node --format=esm --external:electron --external:node-llama-cpp --external:electron-store --external:node:*",
    "build:preload": "esbuild electron/preload/preload.ts --bundle --outfile=dist/preload/preload.js --platform=node --format=cjs --external:electron",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@tiptap/core": "^2.11.0",
    "@tiptap/extension-bubble-menu": "^2.11.0",
    "@tiptap/extension-character-count": "^2.11.0",
    "@tiptap/extension-code-block-lowlight": "^2.11.0",
    "@tiptap/extension-color": "^2.11.0",
    "@tiptap/extension-font-family": "^2.11.0",
    "@tiptap/extension-gapcursor": "^2.11.0",
    "@tiptap/extension-heading": "^2.11.0",
    "@tiptap/extension-highlight": "^2.11.0",
    "@tiptap/extension-image": "^2.11.0",
    "@tiptap/extension-link": "^2.11.0",
    "@tiptap/extension-mention": "^2.11.0",
    "@tiptap/extension-placeholder": "^2.11.0",
    "@tiptap/extension-subscript": "^2.11.0",
    "@tiptap/extension-superscript": "^2.11.0",
    "@tiptap/extension-table": "^2.11.0",
    "@tiptap/extension-table-cell": "^2.11.0",
    "@tiptap/extension-table-header": "^2.11.0",
    "@tiptap/extension-table-row": "^2.11.0",
    "@tiptap/extension-task-item": "^2.11.0",
    "@tiptap/extension-task-list": "^2.11.0",
    "@tiptap/extension-text-align": "^2.11.0",
    "@tiptap/extension-text-style": "^2.11.0",
    "@tiptap/extension-list-keymap": "^2.11.0",
    "@tiptap/extension-underline": "^2.11.0",
    "@tiptap/pm": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0",
    "@tiptap/suggestion": "^2.11.0",
    "electron-store": "^6.0.1",
    "i18next": "^23.16.0",
    "lowlight": "^3.3.0",
    "mammoth": "^1.8.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.0.379",
    "pptxgenjs": "^3.12.0",
    "tippy.js": "^6.3.7",
    "turndown": "^7.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/turndown": "^5.0.5",
    "concurrently": "^8.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.minik.cursus",
    "productName": "Cursus",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "asarUnpack": [
      "node_modules/node-llama-cpp/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Education"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "Cursus-${version}-portable.exe"
    }
  }
}
